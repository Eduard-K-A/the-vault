{
  "expo": {
    "name": "The Vault",
    "slug": "the-vault",
    "scheme": "thevault",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "jsEngine": "hermes",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false
    },
    "plugins": [
      "@journeyapps/react-native-quick-sqlite",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos to set product images.",
          "cameraPermission": "Allow $(PRODUCT_NAME) to use the camera to take product photos."
        }
      ]
    ],
    "android": {
      "package": "com.anonymous.thevault"
    },
    "extra": {
      "eas": {
        "projectId": "392f6168-ffd8-4318-8fda-3d4292e37cab"
      }
    }
  }
}
