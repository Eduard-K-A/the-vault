{
  "expo": {
    "name": "The Vault",
    "slug": "the-vault",
    "scheme": "thevault",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "jsEngine": "hermes",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false
    },
    "extra": {
      "eas": {
        "projectId": "00000000-0000-0000-0000-000000000000"
      }
    },
    "plugins": [
      "@journeyapps/react-native-quick-sqlite"
    ],
    "android": {
      "package": "com.anonymous.thevault"
    }
  }
}
